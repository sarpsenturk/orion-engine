#pragma once

#include "orion-core/platform.h"
#include "orion-core/types.h"

// clang-format off

#define ORION_PLATFORM "@ORION_PLATFORM@"
#cmakedefine01 ORION_PLATFORM_WINDOWS
#cmakedefine01 ORION_PLATFORM_LINUX

#define ORION_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define ORION_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define ORION_VERSION_PATCH @PROJECT_VERSION_PATCH@

#cmakedefine01 ORION_DEBUG_BUILD

// clang-format on

namespace orion
{
#if ORION_PLATFORM_WINDOWS
    inline constexpr auto current_platform = Platform::Windows;
#elif ORION_PLATFORM_LINUX
    inline constexpr auto current_platform = Platform::Linux;
#else
    inline constexpr auto current_platform = Platform::Unknown;
    #warning "You're on unknown/unsupported platform for orion"
#endif

    inline constexpr Version current_version = {ORION_VERSION_MAJOR, ORION_VERSION_MINOR, ORION_VERSION_PATCH};

    inline constexpr bool debug_build = ORION_DEBUG_BUILD;
} // namespace orion
