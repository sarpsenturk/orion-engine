{
  "version": 6,
  "configurePresets": [
    {
      "name": "_root-config",
      "hidden": true,
      "generator": "Ninja",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}install/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "_debug-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "_release-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "_x64-base",
      "hidden": true,
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },
    {
      "name": "_arm64-base",
      "hidden": true,
      "architecture": {
        "value": "ARM64",
        "strategy": "external"
      }
    },
    {
      "name": "_msvc-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "debug-x64-msvc-windows",
      "inherits": [
        "_root-config",
        "_debug-base",
        "_x64-base",
        "_msvc-base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "displayName": "Debug x64 MSVC Windows"
    },
    {
      "name": "release-x64-msvc-windows",
      "inherits": [
        "_root-config",
        "_release-base",
        "_x64-base",
        "_msvc-base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "displayName": "Release x64 MSVC Windows"
    },
    {
      "name": "_clang-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "debug-arm64-clang-macos",
      "inherits": [
        "_root-config",
        "_debug-base",
        "_arm64-base",
        "_clang-base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "displayName": "Debug ARM64 AppleClang macOS"
    },
    {
      "name": "release-arm64-clang-macos",
      "inherits": [
        "_root-config",
        "_release-base",
        "_arm64-base",
        "_clang-base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "displayName": "Release ARM64 AppleClang macOS"
    },
    {
      "name": "_gcc-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "debug-x64-gcc-linux",
      "inherits": [
        "_root-config",
        "_debug-base",
        "_x64-base",
        "_gcc-base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "displayName": "Debug x64 GCC Linux"
    },
    {
      "name": "release-x64-gcc-linux",
      "inherits": [
        "_root-config",
        "_release-base",
        "_x64-base",
        "_gcc-base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "displayName": "Release x64 GCC Linux"
    },
    {
      "name": "debug-x64-clang-linux",
      "inherits": [
        "_root-config",
        "_debug-base",
        "_x64-base",
        "_clang-base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "displayName": "Debug x64 Clang Linux"
    },
    {
      "name": "release-x64-clang-linux",
      "inherits": [
        "_root-config",
        "_release-base",
        "_x64-base",
        "_clang-base"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "displayName": "Release x64 Clang Linux"
    }
  ]
}
